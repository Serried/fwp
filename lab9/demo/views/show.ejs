<!DOCTYPE html>
<html lang="en">
<%- include("head") %>
<body>

<%- include("header") %>

<h2 style="text-align:center; margin:20px 0;">Employee List</h2>

<table class="data-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Last Name</th>
            <th>First Name</th>
            <th>Title</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        <% data.forEach((item)=>{ %>
            <tr>
                <td><%= item.EmployeeId %></td>
                <td><%= item.LastName %></td>
                <td><%= item.FirstName %></td>
                <td><%= item.Title %></td>
                <td><%= item.Phone %></td>
                <td><%= item.Email %></td>
                <td><a href="/delete/<%- item.EmployeeId %>">Delete</a></td>
            </tr>
        <% }); %>
    </tbody>
</table>

<%- include("footer") %>

</body>
</html>
