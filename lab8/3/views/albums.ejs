<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anuphan:wght@100..700&family=Noto+Sans+Thai:wght@100..900&family=Zalando+Sans:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">
    <title>Albums</title>
</head>
<body>
    <h1>Top most popular albums</h1>
    <div class="container">
    <% data.forEach((item) => { %>
        <div class="card">
            <div class="cover">
                <img src="<%= item.album_cover %>" alt="<%= item.album %>">
            </div>
            <div class="content">
                <div class="content-title">
                <strong><p><%= item.song %></p></strong>
            </div>
                <div class="content-details"></div>
                <p>Album: <%= item.album %></p>
                <p>Artist: <%= item.artist %></p>
                <p>Genre: <%= item.genre %></p>
            
            </div>
        </div>

    <% }) %>
</div>
</body>
</html>