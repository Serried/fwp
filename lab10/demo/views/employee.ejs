<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/index.css">
</head>
<body>
    <h1>Panda Company</h1>
    <div id="container">
    <% data.forEach((item) => { %>
        <div id="card">
            <img src="http://webdev.it.kmitl.ac.th:4000/emp-images/<%= item.EmployeeID %>.png">
            <p><%= item.FirstName %> <%= item.LastName %></p>
            <a href="http://webdev.it.kmitl.ac.th:4000/employee/<%= item.EmployeeID %>">
                <button>
                Details
            </button>
            </a>


        </div>
    <% }) %>
</div>
</body>
</html>